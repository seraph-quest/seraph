HOST_DATA_ROOT_DEV=./docker-data/prod

# Root directory for shared services like Ollama.
SHARED_DATA_ROOT=./docker-data/shared

BACKEND_DATA_PATH_DEV=${HOST_DATA_ROOT_DEV}/backend/data
BACKEND_LOGS_PATH_DEV=${HOST_DATA_ROOT_DEV}/backend/logs

# Production provider profile.
# OpenRouter remains the default example; override LLM_API_BASE/LLM_API_KEY for
# OpenAI, Anthropic-through-compatible-gateway, or another OpenAI-compatible endpoint.
OPENROUTER_API_KEY=your-prod-openrouter-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_API_KEY=
LLM_API_BASE=https://openrouter.ai/api/v1
DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096
AGENT_MAX_STEPS=10
DEBUG=false
WORKSPACE_DIR=/app/data
SANDBOX_URL=http://sandbox:8060

# Optional local Ollama sidecar/operator profile.
# LOCAL_MODEL=ollama/qwen2.5-coder:7b
# LOCAL_LLM_API_KEY=
# LOCAL_LLM_API_BASE=http://ollama:11434/v1
# LOCAL_RUNTIME_PATHS=session_title_generation,mcp_*
# RUNTIME_PROFILE_PREFERENCES=session_title_generation=local|default;mcp_*=local|default

# Optional typed provider/operator profiles. Built-ins include openrouter,
# openai-compatible, codex-openai, claude-anthropic, gpt-5.5-low, and
# local-ollama when LOCAL_MODEL is configured. Provider profiles decide who
# thinks; runtime/tool policies decide what the selected route may do.
# LLM_PROVIDER_PROFILES={"profiles":{"team-router":{"provider_kind":"openai_compatible","model":"team/model","api_base":"https://llm.example.com/v1","env_secret":"TEAM_LLM_API_KEY","options":{"reasoning_effort":"low"},"capabilities":["reasoning","tool_use"],"cost":"medium","latency":"low","task":"coding","budget":"medium","fallback":["team/small"],"enabled":true,"safety_notes":"Team-scoped profile; tool permissions remain separate."}}}

# Codex/OpenAI-oriented cloud routing uses OPENAI_API_KEY and low reasoning as
# a request option on codex-openai, not a model-id suffix.
# RUNTIME_PROFILE_PREFERENCES=chat_agent=codex-openai|openrouter;session_title_generation=openai-compatible|openrouter

# Anthropic/Claude-oriented cloud routing uses ANTHROPIC_API_KEY.
# RUNTIME_PROFILE_PREFERENCES=chat_agent=claude-anthropic|openrouter

# Operator routing posture. Tune these to deployment policy and observed quality.
RUNTIME_POLICY_INTENTS=chat_agent=reasoning|tool_use;session_title_generation=fast|cheap;mcp_*=tool_use
RUNTIME_POLICY_REQUIREMENTS=chat_agent=tool_use;mcp_*=tool_use
RUNTIME_POLICY_SCORES=chat_agent=reasoning:5|tool_use:4;session_title_generation=fast:5|cheap:3;mcp_*=tool_use:5
RUNTIME_MODEL_OVERRIDES=
RUNTIME_FALLBACK_OVERRIDES=chat_agent=openai/gpt-4.1-mini|openai/gpt-4.1-nano;session_title_generation=openai/gpt-4.1-nano
RUNTIME_MAX_COST_TIER=session_title_generation=low;mcp_*=medium
RUNTIME_MAX_LATENCY_TIER=session_title_generation=low;mcp_*=medium
RUNTIME_TASK_CLASS=chat_agent=interactive;mcp_*=operator_tooling
RUNTIME_MAX_BUDGET_CLASS=session_title_generation=low;mcp_*=medium

# Provider tags are routing metadata for policy, fallback, and audit surfaces.
# They do not assert equivalent behavior across OpenAI/Codex, Claude, local Ollama,
# OpenRouter, or generic OpenAI-compatible providers.
PROVIDER_CAPABILITY_OVERRIDES=openrouter/anthropic/claude-sonnet-4=reasoning|tool_use;openai/gpt-4.1-mini=reasoning|tool_use;openai/gpt-4.1-nano=fast|cheap;ollama/*=local|fast|cheap
PROVIDER_COST_TIERS=openrouter/anthropic/claude-sonnet-4=high;openai/gpt-4.1-mini=medium;openai/gpt-4.1-nano=low;ollama/*=low
PROVIDER_LATENCY_TIERS=openrouter/anthropic/claude-sonnet-4=medium;openai/gpt-4.1-mini=medium;openai/gpt-4.1-nano=low;ollama/*=low
PROVIDER_TASK_CLASSES=openrouter/anthropic/*=general_reasoning;openai/*=operator_tooling;ollama/*=local_helper
PROVIDER_BUDGET_CLASSES=openrouter/anthropic/claude-sonnet-4=high;openai/gpt-4.1-mini=medium;openai/gpt-4.1-nano=low;ollama/*=low

FALLBACK_MODEL=
FALLBACK_MODELS=openai/gpt-4.1-mini,openai/gpt-4.1-nano
FALLBACK_LLM_API_KEY=
FALLBACK_LLM_API_BASE=
LLM_TARGET_COOLDOWN_SECONDS=300

LLM_LOG_ENABLED=true
LLM_LOG_CONTENT=false
LLM_LOG_DIR=/app/logs
LLM_LOG_MAX_BYTES=52428800
LLM_LOG_BACKUP_COUNT=5
